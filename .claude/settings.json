{
  "permissions": {
    "allow": [
      "Bash(cargo check*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(cargo clippy*)",
      "Bash(cargo fmt*)",
      "Bash(cargo fetch*)",
      "Bash(cargo metadata*)",
      "Bash(cargo tree*)",
      "Bash(cargo --version)",
      "Bash(rustc --version)",
      "Bash(flutter analyze*)",
      "Bash(flutter test*)",
      "Bash(flutter pub get)",
      "Bash(flutter pub outdated)",
      "Bash(flutter --version)",
      "Bash(dart analyze*)",
      "Bash(dart format --output=none*)",
      "Bash(dart --version)",
      "Bash(just lint*)",
      "Bash(just test*)",
      "Bash(just fmt*)",
      "Bash(just check)",
      "Bash(just build-rust)",
      "Bash(just install-hooks)",
      "Bash(just --list)",
      "Bash(bats tests/cli/*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(git ls-files*)",
      "Bash(git check-ignore*)",
      "Bash(git fetch*)",
      "Bash(git remote -v)",
      "Bash(git config --get*)",
      "Bash(git push --force-with-lease*)",
      "Bash(lefthook --help)",
      "Bash(lefthook version)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find . -name *)",
      "Bash(find . -path *)",
      "Bash(find . -type *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(wc -l*)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(jq *)",
      "Bash(.claude/scripts/py *)",
      "Bash(bash -n *)",
      "Bash(.claude/hooks/filter-test-output.sh)",
      "Bash(.claude/hooks/save-artifacts.sh)",
      "Bash(.claude/hooks/session-start.sh)",
      "Bash(./scripts/ai-check.sh)",
      "Bash(./scripts/sync-docs-check.sh)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/google-services.json)",
      "Read(./**/GoogleService-Info.plist)",
      "Read(./**/key.properties)",
      "Read(./**/*.keystore)",
      "Read(./**/*.jks)",
      "Read(./**/*.p12)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git push*--no-verify*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/save-artifacts.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-review.sh"
          }
        ]
      }
    ]
  }
}
