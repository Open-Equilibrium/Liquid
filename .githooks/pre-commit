#!/usr/bin/env bash
# Liquid pre-commit hook
# Install: git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}✓${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; exit 1; }
skip() { echo -e "${YELLOW}–${NC} $1 (not found, skipping)"; }

echo "=== Liquid pre-commit ==="

# ── Rust ─────────────────────────────────────────────────────────────────────
if [ -f "core/Cargo.toml" ]; then
  echo "▸ Rust"

  if ! command -v cargo &>/dev/null; then
    fail "cargo not found. Install Rust: https://rustup.rs"
  fi

  cargo fmt --manifest-path core/Cargo.toml --check \
    || fail "Rust formatting check failed. Run: cargo fmt --manifest-path core/Cargo.toml"
  pass "cargo fmt"

  cargo clippy --manifest-path core/Cargo.toml --all-targets -- -D warnings \
    || fail "Clippy found warnings. Fix all -D warnings before committing."
  pass "cargo clippy"
else
  skip "core/Cargo.toml"
fi

# ── Dart / Flutter ────────────────────────────────────────────────────────────
if [ -f "app/pubspec.yaml" ]; then
  echo "▸ Flutter app"

  if ! command -v flutter &>/dev/null; then
    fail "flutter not found. Install Flutter: https://flutter.dev/docs/get-started"
  fi

  (cd app && dart format --output=none --set-exit-if-changed .) \
    || fail "Dart formatting check failed. Run: dart format . inside app/"
  pass "dart format (app)"

  (cd app && flutter analyze) \
    || fail "Flutter analyze failed. Fix all analyzer errors before committing."
  pass "flutter analyze (app)"
else
  skip "app/pubspec.yaml"
fi

if [ -f "sdk/liquid_sdk/pubspec.yaml" ]; then
  echo "▸ SDK"

  (cd sdk/liquid_sdk && dart format --output=none --set-exit-if-changed .) \
    || fail "Dart formatting check failed in sdk/liquid_sdk. Run: dart format ."
  pass "dart format (sdk)"

  (cd sdk/liquid_sdk && flutter analyze) \
    || fail "Flutter analyze failed in sdk/liquid_sdk."
  pass "flutter analyze (sdk)"
else
  skip "sdk/liquid_sdk/pubspec.yaml"
fi

echo "=== pre-commit passed ==="
